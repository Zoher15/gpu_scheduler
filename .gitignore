# GPU Scheduler - Comprehensive .gitignore

# Log files
*.log
gpu_scheduler.log
running_jobs.log
done_jobs.log
test_output.log

# State and temporary files
*_state.json
test_state.json
gpu_scheduler_state.json.tmp*
*.tmp
*.tmp_*

# Test files (temporary)
test_*.py
jobs_test.txt
test_output.*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDE and editors
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.code-workspace

# Logs directory
/logs/
/tmp/

# Screen session logs
/tmp/gpu_scheduler_logs/

# Backup files
*.bak
*.backup
*.orig

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

